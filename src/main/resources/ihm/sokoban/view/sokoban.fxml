<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="ihm.sokoban.util.SokobanController">

    <!-- Barre du haut : infos niveau -->
    <top>
        <VBox styleClass="top-bar">
            <Label fx:id="labelNiveau" styleClass="titre-niveau" text="Niveau 1" />
            <HBox spacing="20">
                <Label fx:id="labelMouvements" text="Mouvements : 0" />
                <Label fx:id="labelPoussees" text="Poussées : 0" />
                <Label fx:id="labelCaisses" text="Caisses : 0/0" />
            </HBox>
        </VBox>
    </top>

    <!-- Centre : la grille de jeu -->
    <center>
        <StackPane fx:id="stackPlateau">
            <GridPane fx:id="grillePlateau" alignment="CENTER" />
            <!-- Overlay victoire/défaite -->
            <VBox fx:id="overlayMessage" alignment="CENTER" styleClass="overlay" visible="false">
                <Label fx:id="labelMessage" styleClass="message-fin" />
                <Button fx:id="btnAction" onAction="#onNiveauSuivant" text="Niveau suivant" />
            </VBox>
        </StackPane>
    </center>

    <!-- Bas : boutons -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-padding:8;">
            <Button onAction="#onAnnuler" text="↩ Annuler" />
            <Button onAction="#onRecommencer" text="🔄 Recommencer" />
            <Button onAction="#onPrecedent" text="❮ Précédent" />
            <Button onAction="#onSuivant" text="Suivant ❯" />
            <Button onAction="#onQuitter" text="Quitter" />
        </HBox>
    </bottom>

</BorderPane>
